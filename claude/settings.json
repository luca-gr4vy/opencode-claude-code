{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "npx -y @owloops/claude-powerline@latest --style=powerline"
  },
  "permissions": {
    "allow": [
      "Bash(yarn build)",
      "Bash(yarn lint :*)",
      "Bash(yarn test :*)",
      "Bash(pnpm build)",
      "Bash(pnpm lint :*)",
      "Bash(pnpm test :*)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \\\"Claude Code needs your input\\\" with title \\\"Claude Code\\\"'"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \\\"Claude Code is done\\\" with title \\\"Claude Code\\\"'"
          }
        ]
      }
    ]
  }
}
